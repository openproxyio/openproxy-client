{
  "name": "cli-node",
  "version": "1.0.0",
  "description": "Headless CLI Node for OpenProxy Network",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "pm2 start dist/index.js --name openproxy-node --",
    "stop": "pm2 stop openproxy-node",
    "logs": "pm2 logs openproxy-node",
    "run": "node dist/index.js",
    "dev": "ts-node src/index.ts",
    "postinstall": "command -v pm2 >/dev/null 2>&1 || npm install -g pm2",
    "bundle": "esbuild src/index.ts --bundle --platform=node --target=node18 --outfile=dist/bundle.js"
  },
  "dependencies": {
    "commander": "^12.0.0",
    "undici": "^7.24.5",
    "ws": "^8.16.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.24",
    "@types/ws": "^8.5.10",
    "esbuild": "^0.20.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  }
}
